{
  "name": "cc-remote",
  "version": "4.0.0-alpha.1",
  "description": "CC Remote - Claude Code Remote Control (PWA, P2P, no central server)",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node src/server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node src/server/index.js",
    "restart": "node scripts/restart.js",
    "build:exe": "node scripts/build-exe.js",
    "build:zip": "node scripts/build-zip.mjs"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "qrcode": "^1.5.4",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@yao-pkg/pkg": "^6.14.2",
    "adm-zip": "^0.5.10",
    "archiver": "^7.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.0",
    "node-pty": "^1.1.0",
    "pkg": "^5.8.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "puppeteer": "^24.40.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
